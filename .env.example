# Copy to .env only if your tooling loads it; the orchestrator does not require a .env
# for mock mode. Never commit real secrets.

# Optional: absolute path to directory containing cad_intent_envelope.schema.json
# (defaults to repo schemas/ relative to normal installs)
# INGENEER_SCHEMA_DIR=/absolute/path/to/InGENeer/schemas

