{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingenieer.local/schemas/cad_intent_envelope.schema.json",
  "title": "CadIntentEnvelope",
  "description": "Validated CAD execution intent from the orchestrator to the iCAD bridge (InGENeer / AutonomAtIon).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "intentId", "command", "parameters", "executionMode"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.1.0"
    },
    "intentId": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "parameters": {
      "type": "object"
    },
    "executionMode": {
      "type": "string",
      "enum": ["dry_run", "preview", "execute"]
    },
    "humanConfirmationToken": {
      "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    },
    "humanConfirmationId": {
      "type": ["string", "null"]
    },
    "targetDocumentRef": {
      "type": ["string", "null"]
    },
    "modelFingerprintExpected": {
      "type": ["string", "null"]
    }
  }
}
