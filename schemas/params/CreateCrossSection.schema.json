{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingenieer.local/schemas/params/CreateCrossSection.schema.json",
  "title": "CreateCrossSectionParameters",
  "type": "object",
  "required": ["alignment_name", "profile_name", "template_name", "stations", "layer"],
  "properties": {
    "alignment_name": { "type": "string", "minLength": 1 },
    "profile_name": { "type": "string", "minLength": 1 },
    "template_name": { "type": "string", "minLength": 1 },
    "stations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number" }
    },
    "layer": { "type": "string", "minLength": 1 }
  }
}
