{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingenieer.local/schemas/params/PlacePlantingLayout.schema.json",
  "title": "PlacePlantingLayoutParameters",
  "type": "object",
  "required": ["species_id", "points", "mature_spread", "layer"],
  "properties": {
    "species_id": { "type": "string", "minLength": 1 },
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["location"],
        "properties": {
          "location": {
            "type": "array",
            "prefixItems": [
              { "type": "number" },
              { "type": "number" },
              { "type": "number" }
            ],
            "minItems": 3,
            "maxItems": 3
          },
          "rotation": { "type": "number", "default": 0.0 },
          "scale": { "type": "number", "default": 1.0 }
        }
      }
    },
    "mature_spread": { "type": "number", "minimum": 0 },
    "layer": { "type": "string", "minLength": 1 },
    "container_size": { "type": "string" }
  }
}
