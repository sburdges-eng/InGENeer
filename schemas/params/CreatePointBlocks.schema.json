{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingenieer.local/schemas/params/CreatePointBlocks.schema.json",
  "title": "CreatePointBlocksParameters",
  "type": "object",
  "required": ["layer", "blockName", "points"],
  "properties": {
    "layer": { "type": "string", "minLength": 1 },
    "blockName": { "type": "string", "minLength": 1 },
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["location"],
        "properties": {
          "location": {
            "type": "array",
            "prefixItems": [
              { "type": "number" },
              { "type": "number" },
              { "type": "number" }
            ],
            "minItems": 3,
            "maxItems": 3
          },
          "number": { "type": "integer" },
          "elevation": { "type": "number" },
          "description": { "type": "string" },
          "attributes": { "type": "object" }
        }
      }
    }
  }
}
