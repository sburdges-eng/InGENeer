{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingeneer.local/schemas/agentic-event.schema.json",
  "title": "Agentic work chain event",
  "description": "Append-only agent-work telemetry event (separate from product audit chain). See docs/superpowers/plans/2026-06-11-agentic-work-memory-hardening.md §2.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "seq",
    "ts",
    "actor",
    "kind",
    "prev_hash",
    "hash"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "agentic-event/1.0"
    },
    "seq": {
      "type": "integer",
      "minimum": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "description": "e.g. coder-agent, human:PLS_10284, evaluator"
    },
    "kind": {
      "type": "string",
      "enum": [
        "decision",
        "promotion",
        "rejection",
        "correction",
        "session",
        "test_result"
      ]
    },
    "intent": {
      "type": "string"
    },
    "refs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "entity": { "type": "string" },
        "task": { "type": "string" },
        "files": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "inputs_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "outputs_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "prev_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "prior_chain_head": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Optional link to previous session file head hash"
    }
  }
}
